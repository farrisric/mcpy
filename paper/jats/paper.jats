    (equivalently <inline-formula><alternatives>
    <tex-math><![CDATA[\log_{10}(p_\mathrm{H}/p_0)]]></tex-math>
    <mml:math display="inline" xmlns:mml="http://www.w3.org/1998/Math/MathML"><mml:mrow><mml:msub><mml:mi>log</mml:mi><mml:mo>&#8289;</mml:mo><mml:mn>10</mml:mn></mml:msub><mml:mo stretchy="false" form="prefix">(</mml:mo><mml:msub><mml:mi>p</mml:mi><mml:mi mathvariant="normal">H</mml:mi></mml:msub><mml:mi>/</mml:mi><mml:msub><mml:mi>p</mml:mi><mml:mn>0</mml:mn></mml:msub><mml:mo stretchy="false" form="postfix">)</mml:mo></mml:mrow></mml:math></alternatives></inline-formula>
